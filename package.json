{
  "name": "edgerules-react",
  "version": "0.1.0",
  "description": "Reusable React components and hooks for building applications that integrate with the EdgeRules decision engine.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./project-explorer": {
      "import": {
        "types": "./dist/components/project-explorer/index.d.ts",
        "default": "./dist/components/project-explorer/index.js"
      },
      "require": {
        "types": "./dist/components/project-explorer/index.d.cts",
        "default": "./dist/components/project-explorer/index.cjs"
      }
    },
    "./code-editor": {
      "import": {
        "types": "./dist/components/code-editor/index.d.ts",
        "default": "./dist/components/code-editor/index.js"
      },
      "require": {
        "types": "./dist/components/code-editor/index.d.cts",
        "default": "./dist/components/code-editor/index.cjs"
      }
    },
    "./code-editor-cell": {
      "import": {
        "types": "./dist/components/code-editor-cell/index.d.ts",
        "default": "./dist/components/code-editor-cell/index.js"
      },
      "require": {
        "types": "./dist/components/code-editor-cell/index.d.cts",
        "default": "./dist/components/code-editor-cell/index.cjs"
      }
    },
    "./decision-table": {
      "import": {
        "types": "./dist/components/decision-table/index.d.ts",
        "default": "./dist/components/decision-table/index.js"
      },
      "require": {
        "types": "./dist/components/decision-table/index.d.cts",
        "default": "./dist/components/decision-table/index.cjs"
      }
    },
    "./boxed-editor": {
      "import": {
        "types": "./dist/components/boxed-editor/index.d.ts",
        "default": "./dist/components/boxed-editor/index.js"
      },
      "require": {
        "types": "./dist/components/boxed-editor/index.d.cts",
        "default": "./dist/components/boxed-editor/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "format": "prettier --write \"src/**/*.tsx\" \"stories/**/*.tsx\"",
    "format:check": "prettier --check \"src/**/*.tsx\" \"stories/**/*.tsx\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "e2e": "playwright test"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@lezer/highlight": "^1.0.0",
    "@mui/icons-material": "^7.3.0 || ^9.0.0",
    "@mui/material": "^7.3.0 || ^9.0.0",
    "@mui/x-tree-view": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/autocomplete": {
      "optional": true
    },
    "@codemirror/commands": {
      "optional": true
    },
    "@codemirror/language": {
      "optional": true
    },
    "@codemirror/lint": {
      "optional": true
    },
    "@lezer/highlight": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/x-tree-view": {
      "optional": true
    }
  },
  "dependencies": {
    "@edgerules/portable": "0.0.0-alpha.202607152015",
    "@edgerules/web": "0.0.0-alpha.202607152015"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@edgerules/node": "0.0.0-alpha.202607152015",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@lezer/highlight": "^1.2.3",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-tree-view": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "tsup": {
      "esbuild": "0.28.1"
    }
  }
}
