{
  "name": "edgerules-react",
  "version": "0.1.0",
  "description": "Reusable React components and hooks for building applications that integrate with the EdgeRules decision engine.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./project-explorer": {
      "import": {
        "types": "./dist/components/project-explorer/index.d.ts",
        "default": "./dist/components/project-explorer/index.js"
      },
      "require": {
        "types": "./dist/components/project-explorer/index.d.cts",
        "default": "./dist/components/project-explorer/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "e2e": "playwright test"
  },
  "peerDependencies": {
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@mui/icons-material": "^7.3.0 || ^9.0.0",
    "@mui/material": "^7.3.0 || ^9.0.0",
    "@mui/x-tree-view": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/x-tree-view": {
      "optional": true
    }
  },
  "dependencies": {
    "@edgerules/portable": "0.0.0-alpha.202607061133",
    "@edgerules/web": "0.0.0-alpha.202607061133"
  },
  "devDependencies": {
    "@edgerules/node": "0.0.0-alpha.202607061133",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/x-tree-view": "^9.8.0",
    "@playwright/test": "^1.61.0",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "http-server": "^14.1.0",
    "jsdom": "^29.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.6",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
